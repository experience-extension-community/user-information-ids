# Do NOT commit this file once filled in — it contains secrets.
# Copy to .env (`cp sample.env .env` / `copy sample.env .env`) and edit.

# Required for npm run deploy-* and watch-and-upload
EXPERIENCE_EXTENSION_UPLOAD_TOKEN=<upload-token>

# Optional: override the publisher name without editing src/config/institution.js
# PUBLISHER_NAME=<your-institution>

# Optional: pre-fill the Ethos API Key value used as the default in extension.js
# Note: production should set this in Experience Setup, not here.
# ETHOS_API_KEY=<ethos-api-key>

# Optional Setup API toggles. Uncomment any you want to use.
# EXPERIENCE_EXTENSION_SHARED_SECRET=<32+ char secret>
# EXPERIENCE_EXTENSION_ENABLED=<true|false>
# EXPERIENCE_EXTENSION_ENVIRONMENTS=<Tenant1,Tenant2>   # comma-delimited, no spaces
# EXPERIENCE_EXTENSION_RETURN_API_TOKEN=<true|false>   # requires SHARED_SECRET

# Local dev server port (defaults to 8082)
# PORT=8082
